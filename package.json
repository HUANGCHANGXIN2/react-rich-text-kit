{
  "name": "react-rich-text-kit",
  "version": "0.1.1",
  "description": "A reusable Chinese-localized rich text editor package based on Tiptap UI simple-editor.",
  "type": "module",
  "license": "MIT",
  "author": "HUANGCHANGXIN2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HUANGCHANGXIN2/react-rich-text-kit.git"
  },
  "bugs": {
    "url": "https://github.com/HUANGCHANGXIN2/react-rich-text-kit/issues"
  },
  "homepage": "https://github.com/HUANGCHANGXIN2/react-rich-text-kit#readme",
  "keywords": [
    "tiptap",
    "rich-text-editor",
    "react",
    "editor",
    "wysiwyg"
  ],
  "sideEffects": [
    "./dist/style.css"
  ],
  "files": [
    "dist/index.js",
    "dist/index.d.ts",
    "dist/style.css",
    "README.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": {
      "default": "./dist/style.css"
    }
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b",
    "pack:local": "pnpm pack"
  },
  "peerDependencies": {
    "react": ">=18 <20",
    "react-dom": ">=18 <20"
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@tiptap/core": "^3.26.0",
    "@tiptap/extension-highlight": "^3.26.0",
    "@tiptap/extension-horizontal-rule": "^3.26.0",
    "@tiptap/extension-image": "^3.26.0",
    "@tiptap/extension-list": "^3.26.0",
    "@tiptap/extension-subscript": "^3.26.0",
    "@tiptap/extension-superscript": "^3.26.0",
    "@tiptap/extension-text-align": "^3.26.0",
    "@tiptap/extension-typography": "^3.26.0",
    "@tiptap/extensions": "^3.26.0",
    "@tiptap/pm": "^3.26.0",
    "@tiptap/react": "^3.26.0",
    "@tiptap/starter-kit": "^3.26.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sass-embedded": "^1.100.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.5.4"
  },
  "packageManager": "pnpm@10.33.3"
}
